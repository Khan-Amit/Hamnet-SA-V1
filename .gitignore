# ========================================
# hamnet-SA-V1 .gitignore (Updated for Backend)
# ========================================

# OS junk files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# Temporary / cache files
*.log
*.tmp
*.temp
.cache/
*.bak

# === PYTHON BACKEND SPECIFIC ===
__pycache__/
*.pyc
*.pyo
venv/
.venv/
backend/data/
*.pcap
*.cap
*.pcapng

# Node.js (if ever added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Build output
dist/
build/
*.min.js
*.min.css

# SDR / radio hardware config dumps
*.sdr
*.iq
*.bin

# Audio recordings / test files (large)
*.wav
*.mp3
*.webm
*.ogg
*.flac

# Video test files
*.mp4
*.avi
*.mov

# User-specific local config
local-config.js
user-settings.json
