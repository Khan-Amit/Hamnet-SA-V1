# ========================================
# hamnet-SA-V1 .gitignore
# ========================================

# OS junk files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# Temporary / cache files
*.log
*.tmp
*.temp
.cache/
*.bak

# Node.js (if you ever add a backend or build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.env
.env.local

# Build output (if you compile or bundle)
dist/
build/
*.min.js
*.min.css

# SDR / radio hardware config dumps (just in case)
*.sdr
*.iq
*.bin

# Audio recordings / test files (large)
*.wav
*.mp3
*.webm
*.ogg
*.flac

# Video test files
*.mp4
*.avi
*.mov

# GitHub Pages junk (if you deploy)
/.jekyll-cache/
/_site/

# User-specific local config (keep your license intact)
local-config.js
user-settings.json
