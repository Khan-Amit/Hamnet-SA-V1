{
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {}
}{
  "name": "Hamnet-SA-V1 (Snuffer Core)",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {},
  "postCreateCommand": "pip install --upgrade pip && pip install flask flask-cors numpy",
  "postStartCommand": "echo '✅ Python dependencies ready. Run: cd backend && python api_server.py'",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "Snuffer API (Python)",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
